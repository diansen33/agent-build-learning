# 环境变量模板：复制为 .env 后填入真实值
# LLM 配置（OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_BASE_URL=http://model.ic.h3i.buaa.edu.cn/v1
OPENAI_MODEL=Qwen3.5-397B-A17B

# arXiv 检索返回的最大结果数
ARXIV_MAX_RESULTS=5
# arXiv API 端点
ARXIV_API_URL=https://export.arxiv.org/api/query
# arXiv 代理（国内网络下 export.arxiv.org 常超时，填 Clash 等本地代理；留空则直连）
ARXIV_PROXY=http://127.0.0.1:7890
